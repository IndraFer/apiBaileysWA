{
	"name": "api-baileys-wa-hono",
	"version": "1.1.3",
	"description": "Production-ready WhatsApp REST API powered by Baileys 7.0.0-rc.9 with multi-session support, Redis integration, and broadcast queuing.",
	"author": "indrafer",
	"license": "MIT",
	"module": "src/index.ts",
	"scripts": {
		"dev": "bun --watch src/index.ts",
		"start": "bun src/index.ts",
		"dev:node": "tsx watch src/index.ts",
		"start:node": "tsx src/index.ts",
		"build-check": "bunx tsc --noEmit",
		"lint": "bunx @biomejs/biome check src/",
		"format": "bunx @biomejs/biome check --write src/",
		"manage-api-keys": "LOG_LEVEL=warn bun scripts/manage-api-keys.ts",
		"manage-api-keys:node": "LOG_LEVEL=warn tsx scripts/manage-api-keys.ts"
	},
	"dependencies": {
		"@hono/node-server": "^1.19.9",
		"@hono/swagger-ui": "^0.5.0",
		"@hono/zod-openapi": "^0.18.0",
		"@whiskeysockets/baileys": "7.0.0-rc.9",
		"bcryptjs": "^3.0.3",
		"hono": "^4.7.0",
		"lru-cache": "^11.2.5",
		"node-cache": "^5.1.2",
		"pino": "^10.3.0",
		"pino-pretty": "^13.1.3",
		"qrcode": "^1.5.4",
		"redis": "^5.10.0",
		"sharp": "^0.34.5",
		"zod": "^3.24.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.0",
		"@types/bcryptjs": "^3.0.0",
		"@types/qrcode": "^1.5.6",
		"bun-types": "latest",
		"tsx": "^4.21.0"
	}
}
