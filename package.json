{
	"name": "api-baileys-wa-hono",
	"version": "1.3.8",
	"description": "WhatsApp REST API powered by Baileys WA Sockets with multi-session support, Dual-Runtime support, Redis integration, and broadcast queuing.",
	"author": "indrafer",
	"license": "MIT",
	"module": "src/index.ts",
	"scripts": {
		"dev": "bun --watch src/index.ts",
		"start": "bun src/index.ts",
		"dev:node": "tsx watch src/index.ts",
		"start:node": "tsx src/index.ts",
		"build-check": "bunx tsc --noEmit",
		"lint": "bunx @biomejs/biome check src/ --diagnostic-level=error",
		"lint:all": "bunx @biomejs/biome check src/",
		"format": "bunx @biomejs/biome check --write src/",
		"manage-api-keys": "LOG_LEVEL=warn bun scripts/manage-api-keys.ts",
		"manage-api-keys:node": "LOG_LEVEL=warn tsx scripts/manage-api-keys.ts"
	},
	"dependencies": {
		"@hono/node-server": "^1.19.12",
		"@hono/swagger-ui": "^0.6.1",
		"@hono/zod-openapi": "^1.2.4",
		"@whiskeysockets/baileys": "7.0.0-rc10",
		"bcryptjs": "^3.0.3",
		"hono": "^4.12.9",
		"lru-cache": "^11.2.7",
		"node-cache": "^5.1.2",
		"pino": "^10.3.1",
		"pino-pretty": "^13.1.3",
		"qrcode": "^1.5.4",
		"redis": "^5.11.0",
		"sharp": "^0.34.5",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.10",
		"@types/qrcode": "^1.5.6",
		"bun-types": "latest",
		"tsx": "^4.21.0"
	}
}
