# ===================================
# Server Configuration
# ===================================
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=debug

# ===================================
# Authentication
# ===================================
# Simple auth mode: single global token
# Leave empty to disable simple auth (use Redis API keys instead)
# Supported token headers for API requests:
# - Authorization: Bearer <token>
# - x-api-key: <token>
# - x-access-token: <token>
# - token: <token>
AUTH_GLOBAL_TOKEN=your-secret-token-here

# ===================================
# Redis Configuration (Optional)
# ===================================
# Set to true to enable Redis for auth state, API keys, and broadcast queue
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# ===================================
# Baileys Configuration
# ===================================
BAILEYS_LOG_LEVEL=warn
# Use 'default' to auto-fetch latest version
BAILEYS_CLIENT_VERSION=default
# Maximum retry attempts to reconnect (-1 for infinite)
MAX_RETRIES=5
# Delay in ms between reconnection attempts
RECONNECT_INTERVAL=5000
# Maximum concurrent WhatsApp sessions
MAX_SESSIONS=50

# ===================================
# Message Filtering
# ===================================
IGNORE_GROUP_MESSAGES=false
IGNORE_STATUS_MESSAGES=true
IGNORE_BROADCAST_MESSAGES=true
IGNORE_NEWSLETTER_MESSAGES=true
IGNORE_BOT_MESSAGES=true
IGNORE_META_AI_MESSAGES=true

# ===================================
# Auto Reply Configuration
# ===================================
AUTO_REPLY_ENABLED=true
# Always wrap values in double quotes ("text").
# Line Breaks: Use \n for new lines.
# Escaping with backslash: \" for double quotes.
AUTO_REPLY_MESSAGE="Hello, we're currently away.\nWe'll reply to your message soon."
# always, time_range, on_webhook_fail
AUTO_REPLY_TYPE=on_webhook_fail
AUTO_REPLY_TIME_START=18:00
AUTO_REPLY_TIME_END=08:00

# ===================================
# Webhook Configuration
# ===================================
# Global default webhook URL (can be overridden per session)
# Outbound webhook authentication fallback order:
#   per-session webhook secret -> AUTH_GLOBAL_TOKEN (only when fallback is enabled)
WEBHOOK_URL=
# Allow AUTH_GLOBAL_TOKEN as fallback webhook secret when session secret is empty.
# Default behavior in code:
# - development: true
# - production : false
# Set explicitly to avoid ambiguity.
# WARNING: enabling this in production may expose AUTH_GLOBAL_TOKEN to third-party webhook receivers.
WEBHOOK_ALLOW_GLOBAL_TOKEN_FALLBACK=true
# Comma-separated list of allowed events, or 'ALL'
# Available: MESSAGES_UPSERT, MESSAGES_UPDATE, MESSAGES_DELETE, MESSAGES_REACTION,
#            CONNECTION_UPDATE, CHATS_UPSERT, CHATS_UPDATE, CHATS_DELETE,
#            CONTACTS_UPSERT, CONTACTS_UPDATE, GROUPS_UPSERT, GROUPS_UPDATE,
#            GROUP_PARTICIPANTS_UPDATE, PRESENCE_UPDATE, LABELS_EDIT, LABELS_ASSOCIATION,
#            BLOCKLIST_SET, BLOCKLIST_UPDATE, QRCODE_UPDATED, etc.
WEBHOOK_ALLOWED_EVENTS=ALL
# Retry policy for webhook delivery
WEBHOOK_RETRY_MAX=3
WEBHOOK_RETRY_INTERVAL=5000
WEBHOOK_BACKOFF_FACTOR=3
# Signature mode for outbound webhooks:
# - off      : no signature headers
# - optional : include signature headers when a secret is available
# - required : fail send when no secret is available
WEBHOOK_SIGNATURE_MODE=off

# ===================================
# Broadcast / Bulk Message Configuration
# ===================================
# Minimum delay between individual messages (ms)
BROADCAST_MIN_DELAY_MS=1500
# Maximum delay between individual messages (ms)
BROADCAST_MAX_DELAY_MS=3000
# Number of messages to send before a batch pause
BROADCAST_BATCH_SIZE=10
# Pause duration between batches (ms)
BROADCAST_BATCH_PAUSE_MS=5000

# ===================================
# Media Configuration
# ===================================
# Include media as base64 in webhook payloads
MEDIA_INCLUDE_BASE64=false
# Enable automatic cleanup of old media files
MEDIA_CLEANUP_ENABLED=true
# Cleanup interval (ms) - default 1 hour
MEDIA_CLEANUP_INTERVAL_MS=3600000
# Max age of media files (hours)
MEDIA_MAX_AGE_HOURS=24

# ===================================
# CORS Configuration
# ===================================
# Allowed origins for cross-origin requests.
# Use '*' to allow all origins (default, acceptable for API-only servers).
# For multiple domains, use comma-separated values:
# CORS_ORIGIN=https://app1.example.com,https://app2.example.com,https://admin.example.com
# Note: CORS only affects browser requests. Webhooks and server-to-server
# calls are NOT affected by CORS settings.
CORS_ORIGIN=*

# ===================================
# Dashboard Configuration
# ===================================
# Enable/disable the web dashboard (default: true)
DASHBOARD_ENABLED=true
# Allow new user registration (default: false)
# First user can always register (admin setup)
DASHBOARD_REGISTRATION_ENABLED=false
# Require admin approval for newly registered users before first login.
# false = users become active immediately after registration.
# true  = users are created with pending status until approved by an admin.
DASHBOARD_REGISTRATION_REQUIRE_APPROVAL=true
# JWT secret for dashboard sessions (change this in production!)
DASHBOARD_JWT_SECRET=change-this-to-a-random-secret
# Single minimum password length for all environments.
# Keep it simple and consistent (recommended >= 6).
DASHBOARD_PASSWORD_MIN_LENGTH=6

# ===================================
# WA Web Behavior Simulation
# ===================================
# Auto-send "composing" presence before each message (default: true)
SIMULATE_TYPING_BEFORE_SEND=true
# Typing delay range in ms (random between min-max)
SIMULATE_TYPING_DELAY_MIN_MS=1500
SIMULATE_TYPING_DELAY_MAX_MS=3000
# Auto-mark incoming messages as read (default: false, like WA Web toggle)
AUTO_READ_MESSAGES=false
# Auto-set presence to "available" when sending messages (default: true)
AUTO_MARK_ONLINE=true
